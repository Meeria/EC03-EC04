### ── Test erreur : sensor_id inconnu (attend 404) ───────────────────────────
POST {{baseUrl}}/ingest/measures
Content-Type: application/json

{
  "sensor_id": "SENSOR_INCONNU",
  "type": "AIR",
  "timestamp": "{{$timestamp}}000",
  "location": "ZONE_CENTRE",
  "value": 10.0,
  "unit": "μg/m3"
}

### ── Test erreur : type invalide (attend 400) ───────────────────────────────
POST {{baseUrl}}/ingest/measures
Content-Type: application/json

{
  "sensor_id": "SENSOR_AIR_001",
  "type": "INVALID_TYPE",
  "timestamp": "{{$timestamp}}000",
  "location": "ZONE_CENTRE",
  "value": 10.0,
  "unit": "μg/m3"
}

### ── Test erreur : champs manquants (attend 400) ────────────────────────────
POST {{baseUrl}}/ingest/measures
Content-Type: application/json

{
  "sensor_id": "",
  "type": "AIR",
  "timestamp": "{{$timestamp}}000",
  "value": 10.0,
  "unit": "μg/m3"
}

### ── Test Auto-Création de Capteur ──────────────────────────────────────────
POST {{baseUrl}}/ingest/measures
Content-Type: application/json

{
  "sensor_id": "SENSOR_NEW_001",
  "type": "TRAFFIC",
  "timestamp": "{{$timestamp}}000",
  "location": "49.1828; -0.3706",
  "value": 150.0,
  "unit": "km/h"
}
