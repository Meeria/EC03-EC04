# Copier ce fichier en inventory.ini (ignore par git) apres terraform apply.
# Remplacer <INSTANCE_ID> par l'output backend_instance_id,
# et <SSM_TRANSFER_BUCKET> par l'output ssm_transfer_bucket.
[backend]
<INSTANCE_ID> ansible_connection=aws_ssm ansible_aws_ssm_region=eu-west-3 ansible_aws_ssm_bucket_name=<SSM_TRANSFER_BUCKET>
